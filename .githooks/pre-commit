#!/bin/sh
# Block accidental commits of secrets / private state.
# Enable once per clone:  git config core.hooksPath .githooks
# (committed so it travels with the repo, unlike .git/hooks/)

fail=0

# 1) Never-commit filenames (belt-and-suspenders on top of .gitignore)
blocked=$(git diff --cached --name-only |
  grep -iE '(^|/)\.env$|\.env\.[^/]*$|\.session$|\.session-|(^|/)tg_memory\.db|\.lnk$' |
  grep -vE '\.env\.example$')
if [ -n "$blocked" ]; then
  echo "✖ pre-commit: refusing to commit private files:"
  echo "$blocked" | sed 's/^/    /'
  fail=1
fi

# 2) High-signal secret patterns in staged content
if git diff --cached -U0 --no-color | grep -nE \
  'sk-ant-[A-Za-z0-9_-]{20}|(^|[^A-Za-z0-9])pa-[A-Za-z0-9_-]{20}|eyJ[A-Za-z0-9_-]{20,}\.[A-Za-z0-9_-]{20,}\.[A-Za-z0-9_-]+|TG_API_HASH=[0-9a-f]{32}' \
  >/dev/null 2>&1; then
  echo "✖ pre-commit: a staged line looks like an API key / token / TG api_hash."
  echo "  Move it to .env (gitignored). To override once: git commit --no-verify"
  fail=1
fi

[ "$fail" -eq 0 ] || exit 1
exit 0
