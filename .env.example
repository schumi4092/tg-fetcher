# =============================================================================
# tg-fetcher 設定範例 — 複製成 .env 後填入你自己的值
#   cp .env.example .env
# .env 已被 .gitignore 排除,不會上傳。以下未設定的項目都會走 config.py 的預設值。
# =============================================================================

# --- 必要密鑰 ---------------------------------------------------------------
# Telegram API — 從 https://my.telegram.org/apps 取得
TG_API_ID=
TG_API_HASH=

# Claude API key — 從 https://console.anthropic.com 取得(AI_BACKEND=api 時必要)
CLAUDE_API_KEY=

# --- 選用密鑰 ---------------------------------------------------------------
# VoyageAI embedding(選用)— 提升 Memory Ask 的語意搜尋;到 https://www.voyageai.com/ 取得(pa- 開頭)
VOYAGE_API_KEY=

# Twitter / X REST token(選用,Watchtower 抓第一手推文用)— https://6551.io/mcp
TWITTER_TOKEN=

# --- AI 後端 ----------------------------------------------------------------
# api = 走 Anthropic SDK(按 token 計費)、cli = 走本機 Claude Code 訂閱額度
AI_BACKEND=api
# 用 cli 後端且在 Windows 上時,指定 git-bash 路徑(請改成你自己的安裝路徑)
# CLAUDE_CODE_GIT_BASH_PATH=C:\Program Files\Git\bin\bash.exe
# 找不到 claude 執行檔時手動指定
# CLAUDE_CLI_PATH=claude
# CLAUDE_CLI_TIMEOUT=300

# --- 自動抓取 / 自動摘要(以下皆為預設值,取消註解才會覆寫)-------------------
# AUTO_FETCH_INTERVAL_HOURS=12      # 背景抓取間隔;0 = 停用
# AUTO_FETCH_HOURS=12               # 每次抓取回溯的時數
# AUTO_SUMMARIZE_INTERVAL_HOURS=12  # 自動摘要間隔;0 = 停用
# AUTO_SUMMARIZE_HOURS=12           # 每份摘要回溯的時數
# AUTO_SUMMARIZE_HEARTBEAT_SECS=60
# AUTO_SUMMARIZE_IDLE_TIMEOUT_SECS=600
# 固定時刻摘要(Asia/Taipei, HH:MM 逗號分隔);留空 = 走上面的 INTERVAL 模式
# AUTO_SUMMARIZE_TIMES=

# --- GMGN 鏈上持倉對帳(選用,需自備 gmgn-cli)-------------------------------
# ENABLE_GMGN_RECONCILE=0           # Tier-1 即時餘額對帳;1 = 開啟
# ENABLE_GMGN_RECONCILE_RAY=0       # 高流量 wallet_log feed 同功能
# GMGN_RECONCILE_MAX_WALLETS=12     # 單輪對帳錢包數上限
